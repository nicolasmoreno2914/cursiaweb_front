# ============================================================
# Cursia Web Front — Variables de entorno de ejemplo
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env a GitHub.
#
# NOTA: Esta landing page es un sitio estático y actualmente
# no requiere variables de entorno para funcionar. Este archivo
# está preparado para cuando se integren servicios externos.
# ============================================================

# URL pública del sitio (usada para metadatos OG y canonicals)
# SITE_URL=https://cursia.ai

# Clave pública de analytics (si se integra Google Analytics, PostHog, etc.)
# ANALYTICS_KEY=

# Endpoint de formulario de contacto (si se integra Formspree, Basin, etc.)
# FORM_ENDPOINT=

# Variables a configurar en Cloudflare Pages:
# Settings → Environment variables → Add variable
